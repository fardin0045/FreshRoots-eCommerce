# Database
DB_URL=mongodb://127.0.0.1:27017/eCommerce

# Server
PORT=8000

# JWT
SECRET_KEY=your_secret_key_here

# Email Configuration
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password

# Cloudinary (Image Storage)
CLOUD_NAME=your_cloudinary_name
API_KEY=your_cloudinary_api_key
API_SECRET=your_cloudinary_api_secret

# SSL Ecommerce Payment Gateway
STORE_ID=your_ssl_store_id
STORE_PASSWORD=your_ssl_store_password

# Backend API URL used for SSLCommerz callbacks
BACKEND_URL=http://localhost:8000

# Payment Return URL (Optional - defaults to http://localhost:5173)
PAYMENT_RETURN_URL=http://localhost:5173
